<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_main_gradient"
    android:gravity="center">

    <!-- 投屏大图标 -->
    <ImageView
        android:id="@+id/castIcon"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/ic_cast_big"
        android:layout_marginBottom="40dp" />

    <!-- 状态文字 -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="等待投屏"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- 设备名 -->
    <TextView
        android:id="@+id/deviceNameText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="星河助手投屏"
        android:textColor="#99CCFF"
        android:textSize="18sp"
        android:layout_marginBottom="80dp" />

    <!-- 提示信息卡片 -->
    <LinearLayout
        android:layout_width="640dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_cast_tip"
        android:padding="28dp"
        android:layout_marginBottom="20dp">

        <!-- 标题行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_cast_big"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="手机投屏"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 步骤1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:background="@drawable/bg_step_number" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:text="确保手机与电视连接同一WiFi"
                android:textColor="#CCCCCC"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- 步骤2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="2"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:background="@drawable/bg_step_number" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:text="在视频APP中点击「TV」投屏按钮"
                android:textColor="#CCCCCC"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- 步骤3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="3"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:background="@drawable/bg_step_number" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:text="选择「星河助手投屏」开始播放"
                android:textColor="#CCCCCC"
                android:textSize="15sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- 底部版权/版本 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DLNA 投屏接收"
        android:textColor="#666666"
        android:textSize="12sp" />

</LinearLayout>
