<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:touchscreenBlocksFocus="false">

    <!-- 视频画面 -->
    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        android:focusableInTouchMode="false" />

    <!-- 图片显示 -->
    <ImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:visibility="gone"
        android:focusable="false" />

    <!-- 等待/状态文字 -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="等待投屏..."
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:focusable="false" />

    <!-- 缓冲加载圈 -->
    <ProgressBar
        android:id="@+id/bufferingProgress"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:visibility="gone"
        android:focusable="false" />

    <!-- 底部控制栏 -->
    <LinearLayout
        android:id="@+id/controlBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="16dp"
        android:visibility="gone"
        android:focusable="false"
        android:descendantFocusability="afterDescendants">

        <!-- 进度条 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:focusable="false">

            <TextView
                android:id="@+id/currentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:focusable="false" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:focusable="false"
                android:clickable="false"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/totalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:focusable="false" />
        </LinearLayout>

        <!-- 按钮行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:focusable="false">

            <Button
                android:id="@+id/btnBackward"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="快退"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/bg_btn_secondary_selector"
                android:nextFocusRight="@id/btnPlayPause"
                android:nextFocusDown="@id/btnBackward"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnPlayPause"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:text="暂停"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/bg_btn_primary_selector"
                android:nextFocusLeft="@id/btnBackward"
                android:nextFocusRight="@id/btnForward"
                android:nextFocusDown="@id/btnPlayPause"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnForward"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="快进"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/bg_btn_secondary_selector"
                android:nextFocusLeft="@id/btnPlayPause"
                android:nextFocusRight="@id/btnStop"
                android:nextFocusDown="@id/btnForward"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="停止"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/bg_btn_secondary_selector"
                android:nextFocusLeft="@id/btnForward"
                android:nextFocusDown="@id/btnStop"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:stateListAnimator="@null" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
