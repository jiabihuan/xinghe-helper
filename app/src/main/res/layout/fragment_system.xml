<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="32dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 设备信息 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="设备信息"
            android:textColor="@color/accent"
            android:textSize="@dimen/sp14"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="4dp">

            <include layout="@layout/item_sys_info" android:id="@+id/row_brand" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_model" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_manufacturer" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_device" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_serial" />

        </LinearLayout>

        <!-- 操作系统 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="操作系统"
            android:textColor="@color/accent"
            android:textSize="@dimen/sp14"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="4dp">

            <include layout="@layout/item_sys_info" android:id="@+id/row_android_version" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_api_level" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_build_id" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_security_patch" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_kernel" />

        </LinearLayout>

        <!-- 屏幕信息 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="屏幕信息"
            android:textColor="@color/accent"
            android:textSize="@dimen/sp14"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="4dp">

            <include layout="@layout/item_sys_info" android:id="@+id/row_resolution" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_dpi" />

        </LinearLayout>

        <!-- 硬件信息 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="硬件信息"
            android:textColor="@color/accent"
            android:textSize="@dimen/sp14"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="4dp">

            <include layout="@layout/item_sys_info" android:id="@+id/row_cpu" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_cpu_abi" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_cpu_cores" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_cpu_freq" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_hardware" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_board" />

        </LinearLayout>

        <!-- 内存 & 存储 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="内存 &amp; 存储"
            android:textColor="@color/accent"
            android:textSize="@dimen/sp14"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="4dp">

            <include layout="@layout/item_sys_info" android:id="@+id/row_total_memory" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_available_memory" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_storage" />

        </LinearLayout>

        <!-- 网络 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="网络信息"
            android:textColor="@color/accent"
            android:textSize="@dimen/sp14"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="4dp">

            <include layout="@layout/item_sys_info" android:id="@+id/row_ip" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_mac" />

        </LinearLayout>

        <!-- 其他 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="其他信息"
            android:textColor="@color/accent"
            android:textSize="@dimen/sp14"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="4dp">

            <include layout="@layout/item_sys_info" android:id="@+id/row_uptime" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_timezone" />
            <include layout="@layout/item_sys_info" android:id="@+id/row_locale" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>
