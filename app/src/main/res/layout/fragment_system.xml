<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:gravity="center">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#2D2D3A"
        android:layout_marginStart="120dp"
        android:layout_marginEnd="120dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="系统详情"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:maxHeight="500dp"
            android:fillViewport="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <!-- 设备信息 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="设备信息"
                    android:textColor="#00BCD4"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="#252535"
                        android:padding="6dp"
                        android:layout_marginEnd="3dp">

                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_brand" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_model" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_manufacturer" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="#252535"
                        android:padding="6dp"
                        android:layout_marginStart="3dp">

                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_device" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_serial" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_hardware" />

                    </LinearLayout>
                </LinearLayout>

                <!-- 操作系统 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="操作系统"
                    android:textColor="#00BCD4"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="#252535"
                        android:padding="6dp"
                        android:layout_marginEnd="3dp">

                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_android_version" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_api_level" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_build_id" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="#252535"
                        android:padding="6dp"
                        android:layout_marginStart="3dp">

                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_security_patch" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_kernel" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_system_version" />

                    </LinearLayout>
                </LinearLayout>

                <!-- 硬件信息 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="硬件信息"
                    android:textColor="#00BCD4"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="#252535"
                        android:padding="6dp"
                        android:layout_marginEnd="3dp">

                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_cpu" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_cpu_cores" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_cpu_freq" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="#252535"
                        android:padding="6dp"
                        android:layout_marginStart="3dp">

                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_gpu" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_cpu_abi" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_board" />

                    </LinearLayout>
                </LinearLayout>

                <!-- 内存 & 存储 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="内存 &amp; 存储"
                    android:textColor="#00BCD4"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="#252535"
                        android:padding="6dp"
                        android:layout_marginEnd="3dp">

                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_total_memory" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_available_memory" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="#252535"
                        android:padding="6dp"
                        android:layout_marginStart="3dp">

                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_storage" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_screen_res" />

                    </LinearLayout>
                </LinearLayout>

                <!-- 网络 & 其他 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="网络 &amp; 其他"
                    android:textColor="#00BCD4"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="#252535"
                        android:padding="6dp"
                        android:layout_marginEnd="3dp">

                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_ip" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_mac" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_bt_mac" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="#252535"
                        android:padding="6dp"
                        android:layout_marginStart="3dp">

                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_root" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_bootloader_status" />
                        <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_uptime" />

                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="8dp" />

            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/btnClose"
                android:layout_width="100dp"
                android:layout_height="34dp"
                android:text="关闭"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:background="@drawable/bg_dialog_button"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
