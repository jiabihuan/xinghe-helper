<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:gravity="center">

    <LinearLayout
        android:layout_width="600dp"
        android:layout_height="match_parent"
        android:maxHeight="500dp"
        android:orientation="vertical"
        android:background="#2D2D3A"
        android:layout_margin="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="系统详情"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="15dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 设备信息 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="设备信息"
                    android:textColor="#00BCD4"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#252535"
                    android:padding="4dp">

                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_brand" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_model" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_manufacturer" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_device" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_serial" />

                </LinearLayout>

                <!-- 操作系统 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="操作系统"
                    android:textColor="#00BCD4"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#252535"
                    android:padding="4dp">

                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_android_version" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_api_level" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_build_id" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_security_patch" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_kernel" />

                </LinearLayout>

                <!-- 屏幕信息 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="屏幕信息"
                    android:textColor="#00BCD4"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#252535"
                    android:padding="4dp">

                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_resolution" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_dpi" />

                </LinearLayout>

                <!-- 硬件信息 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="硬件信息"
                    android:textColor="#00BCD4"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#252535"
                    android:padding="4dp">

                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_cpu" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_cpu_abi" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_cpu_cores" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_cpu_freq" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_hardware" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_board" />

                </LinearLayout>

                <!-- 内存 & 存储 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="内存 &amp; 存储"
                    android:textColor="#00BCD4"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#252535"
                    android:padding="4dp">

                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_total_memory" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_available_memory" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_storage" />

                </LinearLayout>

                <!-- 网络 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="网络信息"
                    android:textColor="#00BCD4"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#252535"
                    android:padding="4dp">

                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_ip" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_mac" />

                </LinearLayout>

                <!-- 其他 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="其他信息"
                    android:textColor="#00BCD4"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#252535"
                    android:padding="4dp">

                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_uptime" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_timezone" />
                    <include layout="@layout/item_sys_info_dialog" android:id="@+id/row_locale" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="15dp" />

            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="10dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/btnClose"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:text="关闭"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:background="@drawable/bg_dialog_button"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
